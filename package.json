{
  "name": "techstartups",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:link": "dotenv -e .env.local -- sh -c 'supabase link --project-ref $SUPABASE_PROJECT_REF'",
    "db:push": "dotenv -e .env.local -- supabase db push",
    "db:reset": "dotenv -e .env.local -- supabase db reset"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "turbo": "latest"
  }
}
